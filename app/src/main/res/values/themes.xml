<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose paints over this; it exists only for the
         window chrome before Compose draws its first frame.
         Edge-to-edge is handled at runtime via enableEdgeToEdge() in MainActivity. -->
    <style name="Theme.AgarthaVision" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
